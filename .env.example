# PostgreSQL
POSTGRES_USER=contributr
POSTGRES_PASSWORD=contributr_secret
POSTGRES_DB=contributr
DATABASE_URL=postgresql+asyncpg://contributr:contributr_secret@postgres:5432/contributr
DATABASE_URL_SYNC=postgresql+psycopg://contributr:contributr_secret@postgres:5432/contributr

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
SECRET_KEY=change-me-to-a-random-64-char-string
JWT_SECRET=change-me-to-another-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
API_URL=http://backend:8000/api
